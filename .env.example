# ============================================================
# NEAR Market Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables except NEAR_MARKET_API_KEY are optional.
# ============================================================

# --- Required ---

# Your market.near.ai API key (get one at https://market.near.ai/settings)
NEAR_MARKET_API_KEY=sk_live_...

# Anthropic API key — used by Claude Code CLI for agentic builds
# Set this OR authenticate via `claude` CLI interactively
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub Publishing (recommended) ---

# GitHub org or username — code deliverables get pushed here as repos
# Example: GITHUB_ORG=my-org  →  repos created at github.com/my-org/near-job-xxx
# If unset, code deliverables are submitted as text only (no repo push)
GITHUB_ORG=

# Git commit author for deliverable repos (defaults shown)
# GITHUB_AUTHOR_NAME=NEAR Market Agent
# GITHUB_AUTHOR_EMAIL=agent@market.near.ai

# --- Web Research (recommended) ---

# Tavily API key — enables deep research before building
# Get one free at https://tavily.com (1,000 queries/mo, no credit card)
# If unset, research relies on npm/pypi lookups + LLM knowledge only
TAVILY_API_KEY=

# --- Agent Behavior ---

# NEAR_MARKET_URL=https://market.near.ai
# MIN_BUDGET_NEAR=1.0            # Skip jobs below this budget
# MAX_CONCURRENT_JOBS=3          # Max parallel jobs
# POLL_INTERVAL=60               # Seconds between scan cycles
# BID_THRESHOLD=0.6              # Min evaluation score to bid (0.0-1.0)
# CLAUDE_MODEL=claude-sonnet-4-20250514  # LLM for evaluation + building
# MAX_TOKENS=4096
# DRY_RUN=false                  # Evaluate without placing real bids
# VERBOSE=false                  # Extra logging
# LOG_DIR=logs                   # State + log directory

# --- Per-Tier Settings ---

# Timeouts (seconds) for builder agent per job tier
# TIER_TEXT_TIMEOUT=300
# TIER_PACKAGE_TIMEOUT=600
# TIER_SERVICE_TIMEOUT=900
# TIER_SYSTEM_TIMEOUT=1200

# Model overrides per tier (leave unset to use CLAUDE_MODEL)
# TIER_TEXT_MODEL=
# TIER_PACKAGE_MODEL=
# TIER_SERVICE_MODEL=
# TIER_SYSTEM_MODEL=

# Comma-separated tiers to skip (won't bid on these)
# DISABLED_TIERS=system
